                 {
                     "name":  "Auth - Login (Admin)",
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "const data = pm.response.json();",
                                                                   "pm.collectionVariables.set(\u0027token\u0027, data.access_token);",
                                                                   "pm.test(\u0027Token generado\u0027, function () {",
                                                                   "  pm.expect(data).to.have.property(\u0027access_token\u0027);",
                                                                   "});"
                                                               ]
